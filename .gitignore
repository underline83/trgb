# ==============
#  MACOS TRASH
# ==============
.DS_Store
.AppleDouble
.LSOverride
._*
Icon?
# ATTENZIONE: la regola "Icon?" sopra (marker macOS Finder)
# matcha anche "icons" come glob — dobbiamo ri-includere esplicitamente
# la cartella PWA icons, altrimenti git ignora tutte le icone Apple/PWA
# e il deploy va in produzione senza icone (manifest + apple-touch-icon → 404).
!frontend/public/icons/
!frontend/public/icons/**
ehthumbs.db
Thumbs.db

# =====================
#  PYTHON / FASTAPI
# =====================
__pycache__/
*.py[cod]
*$py.class

# Virtualenv
venv/
venv-trgb/
.env/
.python-version

# =====================
#  TRGB DATABASE / BACKUP
# =====================
app/data/*.db
app/data/*.db-wal
app/data/*.db-shm
# File di backfill v2.0a2 (dry-run generato dalla mig 057 e approved per apply)
app/data/backfill_*.csv
app/data/*.sqlite3
app/data/*.prev
app/data/.fuse_hidden*
app/data/backups/
app/data/users.json
# modules.json è tracciato in git come SEED (default ruoli/permessi).
# Lo stato effettivo vive in modules.runtime.json che NON va in git,
# altrimenti ogni push.sh riporta i ruoli ai default (bug B1 problemi.md)
app/data/modules.runtime.json
app/data/modules.runtime.meta.json
*.backup

# ⚠️ CARTELLE RUNTIME SCRITTE DAL BACKEND — DEVONO essere ignorate,
# altrimenti il post-receive hook del VPS (`git clean -fd`) le cancella
# ad ogni push.sh perché sono viste come untracked.
# Bug del 11/04/2026: i cedolini PDF importati sono scomparsi dopo un push
# perché `app/data/cedolini/` non era in .gitignore e il hook ha fatto pulizia.
app/data/cedolini/
app/data/documenti_dipendenti/
app/data/uploads/
app/data/ipratico_uploads/

# =====================
#  NODE / VITE / REACT
# =====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
dist-ssr/
*.local
*.cache/
.vite/
.vscode/

# Frontend specific
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.DS_Store
frontend/._*

