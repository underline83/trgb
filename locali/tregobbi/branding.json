{
  "_comment": "Branding Osteria Tre Gobbi — palette TRGB-02 (sessione 28 originale, sessione 60 R2 portata in tenant config). Modulo: vini/platform UI primitives.",
  "_estratto_da": "frontend/src/index.css :root (palette CSS vars) + tailwind.config.js (theme.extend.colors) + frontend/index.html (theme-color) + CLAUDE.md sezione palette",

  "id": "tregobbi",
  "wordmark_text": "TRGB",
  "tagline": "Osteria Tre Gobbi",

  "colors": {
    "brand_red": "#E8402B",
    "brand_green": "#2EB872",
    "brand_blue": "#2E7BE8",
    "brand_ink": "#111111",
    "brand_cream": "#F4F1EC",
    "brand_night": "#0E0E10",
    "_note_ruoli": "I 6 colori ruolo (amber admin, cyan contabile, purple sommelier, rose sala, emerald chef, slate viewer) restano i Tailwind standard, NON sono parte del branding tenant — sono affordance funzionale comune al prodotto."
  },

  "theme": {
    "background": "#F4F1EC",
    "foreground": "#111111",
    "primary": "#2E7BE8",
    "success": "#2EB872",
    "danger":  "#E8402B",
    "page_bg_class": "bg-brand-cream",
    "html_theme_color": "#F4F1EC",
    "html_apple_status_bar_style": "black-translucent"
