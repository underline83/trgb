# Template env.production per nuovo locale TRGB (R4, sessione 60).
# Quando arriva un cliente nuovo:
#   cp -r locali/_template locali/<id_cliente>
#   mv locali/<id_cliente>/deploy/env.production.template locali/<id_cliente>/deploy/env.production
#   editare i valori sotto con quelli reali del cliente
#
# Sourceato da push.sh:  ./push.sh -l <id_cliente> "msg"

# ── VPS target deploy ──
VPS_HOST=<alias_ssh_o_ip>             # alias SSH dal ~/.ssh/config oppure IP diretto
VPS_DIR=<path_repo_sul_vps>           # working dir del repo deploy sul VPS cliente
VENV=<path_venv_python>               # Python venv del backend cliente

# ── Identità del locale ──
TRGB_LOCALE=<id_cliente>              # stesso ID della cartella locali/<id_cliente>
DOMAIN=<dominio_cliente>              # es. gestionale.osteriapinco.it
PROBE_URL=https://<dominio_cliente>/

# ── Servizi systemd ──
BACKEND_SERVICE=trgb-backend-<id_cliente>     # un service per cliente per evitare collisioni
FRONTEND_SERVICE=trgb-frontend-<id_cliente>
BACKEND_PORT=<porta>                  # consigliato 8000+N per ogni cliente

# ── Upload utenti ──
TRGB_UPLOADS_DIR=<path_uploads>       # consigliato /var/lib/trgb/<id_cliente>/uploads
